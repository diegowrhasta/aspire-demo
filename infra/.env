# Container image name for apiservice
APISERVICE_IMAGE=aspireapp1.apiservice:latest

# Default container port for apiservice
APISERVICE_PORT=5320

# Parameter password
PASSWORD=123456

# Container image name for rabbitConsumer
RABBITCONSUMER_IMAGE=aspireapp1.rabbitconsumer:latest

# Default container port for rabbitConsumer
RABBITCONSUMER_PORT=5074

# Container image name for sql-probe
SQL_PROBE_IMAGE=mssqlprobe.apiservice:latest

# Default container port for sql-probe
SQL_PROBE_PORT=5133

# Parameter username
USERNAME=admin

# Container image name for webfrontend
WEBFRONTEND_IMAGE=aspireapp1.web:latest

# Default container port for webfrontend
WEBFRONTEND_PORT=5070

